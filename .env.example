# Warehance API
WAREHANCE_API_KEY=WH_xxxxx

# Google Service Account JSON file path
GOOGLE_SERVICE_ACCOUNT_FILE=config/service_account.json

# Telegram Notifications
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Google Drive Backup folder name
GDRIVE_BACKUP_FOLDER=Warehance Backups

# Sync Settings
SYNC_DAYS_BACK=1
SYNC_MODE=append
LOG_LEVEL=INFO

# Client Discovery (v2.1)
ENABLE_CLIENT_DISCOVERY=true

# Google Drive Backup (v2.0)
ENABLE_GDRIVE_BACKUP=false
