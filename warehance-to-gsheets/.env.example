# ============================
# Warehance API Configuration
# ============================
WAREHANCE_API_KEY=your_warehance_api_key_here
WAREHANCE_BASE_URL=https://api.warehance.com/v1

# ============================
# Google Sheets Configuration
# ============================
# Path to your Google Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=config/service_account.json

# Spreadsheet IDs are in clients.json (per client)

# ============================
# Sync Settings
# ============================
# How many days back to fetch (default: 1 for daily sync)
SYNC_DAYS_BACK=1

# Mode: "append" adds new rows, "replace" clears and rewrites the sheet
SYNC_MODE=append

# ============================
# Logging
# ============================
LOG_LEVEL=INFO
LOG_FILE=logs/sync.log
